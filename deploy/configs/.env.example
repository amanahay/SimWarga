# ============================================
# SimWarga - Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your values

# Node Environment
NODE_ENV=production

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_PATH=./backend/simwarga.db

# JWT Secret (IMPORTANT: Generate a strong secret key)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Configuration (list of allowed origins)
# For smarterasp.net, add your domain(s) here
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Optional: Application Settings
LOG_LEVEL=info
DEBUG=false

# Optional: File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Optional: Email Configuration (for notifications)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional: SMS API Configuration
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=
